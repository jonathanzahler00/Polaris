# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# claude code
.claude/

# admin/internal documentation (keep private, visible only locally)
ADMIN.md
DEPLOYMENT.md
FEATURES.md
WIDGETS.md
STRUCTURE.md
STORE_RELEASE.md

# database schema (keep private)
supabase/

# typescript
*.tsbuildinfo
next-env.d.ts

# Vercel CLI
AGENTS.md

# Android - sensitive config (key is restricted, but don't re-expose on future public repo)
android-widget/app/google-services.json

# Capacitor native build artifacts
android/app/build/
android/.gradle/
android/local.properties
ios/App/Pods/
ios/DerivedData/
.env*.local
